# LLM API keys — at least one provider required
# autoessay auto-detects which keys are present and configures accordingly

# Anthropic (recommended for smart tier — Opus, Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek (strong fast tier — deepseek-chat, deepseek-reasoner)
DEEPSEEK_API_KEY=sk-...

# OpenRouter (multi-provider, key alone gives access to many models)
OPENROUTER_API_KEY=sk-or-v1-...

# Z.ai / GLM (alternative fast/smart tier)
ZAI_API_KEY=...

# Optional: academic citation verification
CROSSREF_EMAIL=your@email.com
